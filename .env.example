# ─────────────────────────────────────────────
# FamilyFinanceBot · Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Anthropic (Claude API)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Números autorizados (com código do país, sem + ou espaços)
# Exemplo: 5511999998888,5511988887777
ALLOWED_NUMBERS=5511999998888,5511988887777

# Ambiente
NODE_ENV=development
