# ─────────────────────────────────────────────
# FamilyFinanceBot · Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Anthropic (Claude API)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Bargainly API Base URL
# Produção:    https://app.bargainly.com.br/api
# Development: http://localhost:8888/api
API_BASE_URL=https://app.bargainly.com.br/api

# Números autorizados (com código do país, sem + ou espaços)
# Exemplo: 5511999998888,5511988887777
ALLOWED_NUMBERS=5511999998888,5511988887777

# Ambiente
NODE_ENV=development
